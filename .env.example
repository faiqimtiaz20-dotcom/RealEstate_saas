# Root / workspace — copy to apps/web/.env for local overrides

# Public API base (optional). UI-only defaults to /api
VITE_API_BASE_URL=http://localhost:4000

# Dashboard: set to true to call GET /v1/dashboard/summary?range=7d|30d|90d|12m (falls back to mocks on error)
VITE_DASHBOARD_LIVE_API=false
